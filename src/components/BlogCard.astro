---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags = [] } = Astro.props;

const formatted = new Date(date).toLocaleDateString('en-US', {
  year: '2-digit',
  month: '2-digit',
  day: '2-digit',
}).replace(/\//g, '.');
---

<a href={`/blog/${slug}`} class="group block py-6">
  <time
    datetime={date.toISOString()}
    class="block text-xs mb-2 tabular-nums"
    style={`color: var(--color-text-secondary);`}
  >
    {formatted}
  </time>
  <h3 class="text-lg font-semibold tracking-tight leading-snug group-hover:underline decoration-1 underline-offset-3">
    {title}
  </h3>
  <p class="mt-2 text-sm leading-relaxed" style={`color: var(--color-text-secondary);`}>
    {description}
  </p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-3">
      {tags.map((tag: string) => (
        <span
          class="text-xs font-medium px-2.5 py-0.5 rounded-full"
          style={`background: var(--color-bg-secondary); color: var(--color-text-secondary); border: 1px solid var(--color-border);`}
        >
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
