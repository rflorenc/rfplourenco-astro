---
---

<div class="py-16 md:py-24">
  <svg
    viewBox="0 0 400 160"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="max-w-sm md:max-w-md"
    role="img"
    aria-label="re:shift — Ricardo Lourenço engineering blog"
  >
    <!-- re:shift logo -->
    <text
      x="0"
      y="48"
      font-family="'JetBrains Mono', 'Fira Code', monospace"
      font-size="42"
      font-weight="700"
      letter-spacing="-1"
    >
      <tspan style={`fill: var(--color-accent);`}>re</tspan><tspan style="fill: var(--color-text); opacity: 0.3;">:</tspan><tspan style={`fill: var(--color-text);`}>shift</tspan>
    </text>

    <!-- Separator line -->
    <line
      x1="0"
      y1="68"
      x2="120"
      y2="68"
      stroke-width="2"
      style={`stroke: var(--color-border);`}
    />

    <!-- Name -->
    <text
      x="0"
      y="100"
      font-family="'Inter', system-ui, sans-serif"
      font-size="18"
      font-weight="500"
      style={`fill: var(--color-text);`}
    >
      Ricardo Lourenço
    </text>

    <!-- Tagline -->
    <text
      x="0"
      y="128"
      font-family="'Inter', system-ui, sans-serif"
      font-size="14"
      style={`fill: var(--color-text-secondary);`}
    >
      engineering blog
    </text>

    <!-- Terminal cursor blink -->
    <rect
      x="134"
      y="114"
      width="2"
      height="18"
      style={`fill: var(--color-accent);`}
    >
      <animate attributeName="opacity" values="1;0;1" dur="1.2s" repeatCount="indefinite" />
    </rect>
  </svg>
</div>
