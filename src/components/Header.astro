---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50" style={`background-color: var(--color-bg); border-bottom: 1px solid var(--color-border);`}>
  <nav class="mx-auto max-w-7xl px-8 h-15 flex items-center justify-between">
    <a href="/" class="text-lg font-bold tracking-tight" style="font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace; letter-spacing: -0.03em;">
      <span style={`color: var(--color-accent);`}>re</span><span class="opacity-40">:</span>shift
    </a>
    <div class="flex items-center gap-8">
      <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'text-sm font-medium transition-opacity duration-150',
                currentPath.startsWith(href) ? 'opacity-100' : 'opacity-55 hover:opacity-80',
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        class="md:hidden p-1 cursor-pointer bg-transparent border-none"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden px-6 pb-4" style={`border-top: 1px solid var(--color-border);`}>
    <ul class="flex flex-col gap-4 pt-4 list-none m-0 p-0">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm font-medium block',
              currentPath.startsWith(href) ? 'opacity-100' : 'opacity-55',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
