---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<BaseLayout title="Blog — re:shift" description="Writing about software engineering">
  <div class="mx-auto max-w-5xl px-6 py-16 md:py-24">
    <h1 class="text-3xl md:text-4xl font-bold tracking-tighter">Blog</h1>
    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-6">
        {allTags.map((tag) => (
          <a
            href={`/blog/tags/${tag}`}
            class="text-xs font-medium px-3 py-1 rounded-full hover:opacity-70 transition-opacity"
            style={`background: var(--color-bg-secondary); color: var(--color-text-secondary); border: 1px solid var(--color-border);`}
          >
            {tag}
          </a>
        ))}
      </div>
    )}
    {posts.length === 0 ? (
      <p class="mt-8" style={`color: var(--color-text-secondary);`}>No posts yet.</p>
    ) : (
      <div class="mt-8">
        {posts.map((post, i) => (
          <div>
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.slug}
              tags={post.data.tags}
            />
            {i < posts.length - 1 && (
              <hr style={`border: none; border-top: 1px solid var(--color-border);`} />
            )}
          </div>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
