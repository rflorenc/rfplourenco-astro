---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBrand from '../components/HeroBrand.astro';
import FeaturedPost from '../components/FeaturedPost.astro';
import BlogCard from '../components/BlogCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const [latestPost, ...recentPosts] = allPosts;
const displayPosts = recentPosts.slice(0, 3);

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))].sort();
const tagCounts = new Map<string, number>();
allPosts.forEach((post) => post.data.tags.forEach((tag) => tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1)));
---

<BaseLayout title="re:shift — Ricardo's Engineering Blog">
  <div class="mx-auto max-w-5xl px-6">

    <HeroBrand />

    <hr style={`border: none; border-top: 1px solid var(--color-border);`} />

    <div class="flex flex-col md:flex-row gap-12 md:gap-16">

      <!-- Sidebar: Tags -->
      <aside class="md:w-44 shrink-0 pt-12 md:pt-16">
        <h2 class="text-xs font-semibold uppercase tracking-widest mb-4" style={`color: var(--color-text-secondary);`}>
          Topics
        </h2>
        <nav class="flex flex-row flex-wrap gap-2 md:flex-col md:gap-0">
          {allTags.map((tag) => (
            <a
              href={`/blog/tags/${tag}`}
              class="group flex items-center justify-between py-1.5 md:py-2 text-sm transition-opacity hover:opacity-100 opacity-60"
            >
              <span class="group-hover:underline decoration-1 underline-offset-2">{tag}</span>
              <span
                class="hidden md:inline text-xs ml-2 tabular-nums"
                style={`color: var(--color-text-secondary);`}
              >
                {tagCounts.get(tag)}
              </span>
            </a>
          ))}
        </nav>
      </aside>

      <!-- Main content -->
      <div class="flex-1 min-w-0">

        {latestPost && (
          <section>
            <FeaturedPost
              title={latestPost.data.title}
              description={latestPost.data.description}
              slug={latestPost.slug}
            />
          </section>
        )}

        <hr style={`border: none; border-top: 1px solid var(--color-border);`} />

        {displayPosts.length > 0 && (
          <section class="py-12 md:py-16">
            <h2 class="text-xs font-semibold uppercase tracking-widest mb-2" style={`color: var(--color-text-secondary);`}>
              Latest Posts
            </h2>
            {displayPosts.map((post, i) => (
              <div>
                <BlogCard
                  title={post.data.title}
                  description={post.data.description}
                  date={post.data.date}
                  slug={post.slug}
                  tags={post.data.tags}
                />
                {i < displayPosts.length - 1 && (
                  <hr style={`border: none; border-top: 1px solid var(--color-border);`} />
                )}
              </div>
            ))}
            <a
              href="/blog"
              class="inline-block mt-4 text-sm font-medium hover:underline decoration-1 underline-offset-2"
              style={`color: var(--color-accent);`}
            >
              See all posts &rarr;
            </a>
          </section>
        )}

        <hr style={`border: none; border-top: 1px solid var(--color-border);`} />

        {projects.length > 0 && (
          <section class="py-12 md:py-16">
            <h2 class="text-xs font-semibold uppercase tracking-widest mb-2" style={`color: var(--color-text-secondary);`}>
              Projects
            </h2>
            {projects.map((project, i) => (
              <div>
                <ProjectCard
                  title={project.data.title}
                  description={project.data.description}
                  tech={project.data.tech}
                  url={project.data.url}
                  repo={project.data.repo}
                />
                {i < projects.length - 1 && (
                  <hr style={`border: none; border-top: 1px solid var(--color-border);`} />
                )}
              </div>
            ))}
            <a
              href="/projects"
              class="inline-block mt-4 text-sm font-medium hover:underline decoration-1 underline-offset-2"
              style={`color: var(--color-accent);`}
            >
              See all projects &rarr;
            </a>
          </section>
        )}
      </div>

    </div>
  </div>
</BaseLayout>
